# ============================================================
# Oracle Cloud VM — Environment Variables Template
# Copy file này thành .env trên VM, điền giá trị thực vào
# KHÔNG commit file .env lên git
# ============================================================

# ── Application ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

JWT_SECRET=CHANGE_ME_AT_LEAST_256_BIT_RANDOM_STRING_HERE
API_GATEWAY_PORT=8085

VNSTOCK_API_KEY=

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ── Grafana Cloud ─────────────────────────────────────────────
# Lấy từ: grafana.com → Stack → Connections → Hosted Prometheus
GRAFANA_CLOUD_PROMETHEUS_URL=https://prometheus-prod-XX-prod-XX.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_USERNAME=NUMERIC_ID_HERE

# Lấy từ: grafana.com → Stack → Connections → Hosted Logs (Loki)
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USERNAME=NUMERIC_ID_HERE

# Lấy từ: grafana.com → Administration → API Keys → Create (role: MetricsPublisher)
GRAFANA_CLOUD_API_KEY=glc_eyJ...

# ── Oracle VM ────────────────────────────────────────────────
ORACLE_VM_HOSTNAME=invest-oracle-vm
