# Environment variables for docker-compose
# Copy to .env and fill in real values before running docker compose.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT — CHANGE THIS to a random 32+ character string in production
JWT_SECRET=InvestAdvisorJwtSecretKeyMustBeAtLeast256BitsLong2024!

# Email (SMTP) — used by notification-service
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your_app_password_here
