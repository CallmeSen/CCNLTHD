# ===== LLM provider (OpenRouter — dùng 1 API key cho mọi model) =====
# Đăng ký tại https://openrouter.ai/ → Keys → Create key
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model mặc định. Verify ID hiện còn live tại https://openrouter.ai/models
OPENROUTER_MODEL=openrouter/anthropic/claude-sonnet-4-5
OPENROUTER_FALLBACK_MODEL=openrouter/google/gemini-2.0-flash-exp:free

# ===== Tools (optional — chỉ cần nếu muốn dùng web search / scraping thật) =====
SERPER_API_KEY=          # https://serper.dev/ (free tier)
BROWSERLESS_API_KEY=     # https://www.browserless.io/ (free tier)

# ===== Database & Cache (Giai đoạn 1 — chưa dùng ở Giai đoạn 0) =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_service
REDIS_URL=redis://localhost:6379/0
