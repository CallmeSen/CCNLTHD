# Database Configuration
DATABASE_URL=postgresql://xxx:xxxx@localhost:xxxx/financial_advisor
POSTGRES_USER=xxx
POSTGRES_PASSWORD=xxxx
POSTGRES_DB=financial_advisor

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# LLM Configuration â€” OpenRouter
OPENROUTER_API_KEY=your_openrouter_key_here
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_MAX_RETRIES=2

# Legacy (kept for fallback only)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Feature Flags
ENABLE_AUDIT_LOGGING=true
ENABLE_HUMAN_REVIEW=true
ENABLE_CRITIC_AGENT=true

# Storage
STORAGE_PATH=./storage

TAVILY_API_KEY= your_tavily_api_key_here
BENCHMARK_TICKER=^GSPC
RISK_FREE_RATE=0.045
EXPECTED_MARKET_RETURN=0.09